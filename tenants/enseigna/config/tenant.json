{
  "blog_id": "enseigna",
  "display_name": "Enseigna.fr",
  "domain": "enseigna.fr",
  "gsc_property": "https://enseigna.fr/",
  "auth_mode": "service_account",
  "wp_api_config": {
    "api_base_url": "https://enseigna.fr/wp-json/wp/v2",
    "user_env_var": "WP_ENSEIGNA_USER",
    "password_env_var": "WP_ENSEIGNA_APP_PASSWORD",
    "timeout": 30
  },
  "content_type": "review_comparatif",
  "subject_category": "education_reviews",
  "ytg": {
    "enabled": true,
    "gate": false,
    "group_id": 82174,
    "lang": "fr",
    "keyword_sources": [
      "notion",
      "sheet",
      "gsc",
      "slug"
    ]
  },
  "tone_profile": {
    "style": "expert_analytique",
    "formality": "formal",
    "voice": "testeur_objectif",
    "characteristics": [
      "Objectif et factuel",
      "Comparatifs chiffrés",
      "Verdicts nuancés",
      "Points positifs ET négatifs"
    ]
  },
  "seo_settings": {
    "min_word_count": 1500,
    "max_word_count": 2500,
    "superprof_link_required": true,
    "max_external_links": 2,
    "keyword_density_target": 0.015
  },
  "refresh_thresholds": {
    "stale_months": 6,
    "critical_months": 12,
    "ctr_low_threshold": 2.0,
    "impression_high_threshold": 500,
    "position_decline_alert": 5
  },
  "content_structure": {
    "required_sections": [
      "tableau_evaluation",
      "points_forts",
      "points_faibles",
      "tarifs",
      "verdict_final"
    ],
    "rating_system": {
      "enabled": true,
      "scale": 10,
      "criteria": [
        "qualite_pedagogique",
        "rapport_qualite_prix",
        "interface_ux",
        "support_client"
      ]
    },
    "comparison_table_mandatory": true
  },
  "prompt_overrides": {
    "intro_style": "Commencer par un verdict rapide (note/10 + résumé 1 phrase)",
    "structure_requirement": "Tableau comparatif obligatoire en début d'article",
    "tone_requirement": "Ton de testeur expert, objectif et impartial",
    "cta_format": "Section 'Notre verdict final' avec recommandation claire"
  },
  "special_rules": {
    "independence_statement": "Cet article est indépendant. Nous ne recevons aucune compensation de [Plateforme] pour cet avis.",
    "methodology_disclosure": true,
    "price_verification_required": true,
    "competitor_blacklist_strict": true
  },
  "article_templates": {
    "avis": {
      "title_pattern": "Avis sur {platform} : Test Complet {year}",
      "required_sections": [
        "evaluation_table",
        "test_methodology",
        "pros",
        "cons",
        "pricing",
        "verdict"
      ]
    },
    "comparatif": {
      "title_pattern": "{platform_a} vs {platform_b} : Comparatif {year}",
      "required_sections": [
        "comparison_table",
        "detailed_comparison",
        "recommendations",
        "verdict"
      ]
    }
  },
  "sheets": {
    "spreadsheet_id": "1rNRU2WzlqfsAvFDjJHDN3ChCZ3u0NIfRaPoM4s1MzEM",
    "spreadsheet_env": "SPREADSHEET_ID_ENSEIGNA",
    "tabs": [
      {
        "name": "Avis",
        "col_url": 0,
        "col_keyword": 1
      },
      {
        "name": "Versus",
        "col_url": 0,
        "col_keyword": 1
      },
      {
        "name": "A ajouter",
        "col_url": 0,
        "col_keyword": 3
      }
    ],
    "status_col": "F"
  },
  "scraping_config": {
    "article_body": "article.post-content, article.entry-content, .post-content, .entry-content",
    "exclude_selectors": [
      "nav",
      "aside.sidebar",
      ".navigation",
      ".comments",
      "footer.entry-footer",
      ".related-posts",
      ".sharedaddy"
    ],
    "timeout": 30,
    "requires_playwright": false
  }
}
