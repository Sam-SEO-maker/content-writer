    "no_pronouns": true
  },
  "linking_rules": {
    "blog_to_blog_anchor_types": [
      "warm",
      "cold"
    ],
    "blog_to_landing_anchor_types": [
      "money"
    ],
    "landing_url_marker": "/lessons/",
    "blog_url_marker": "/blog/"
  },
  "sheets": {
    "spreadsheet_id": "1Vutb06Fcm3awnANPbtLkI1EvhbE9d-TXrZRLTrmmLlQ",
