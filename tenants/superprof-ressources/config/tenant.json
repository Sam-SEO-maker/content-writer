  "wp_api_config": {
    "api_base_url": "https://www.superprof.fr/ressources/wp-json/wp/v2",
    "user_env_var": "WP_SUPERPROF_RESSOURCES_USER",
    "password_env_var": "WP_SUPERPROF_RESSOURCES_APP_PASSWORD",
