{
  "_comment": "Dispatch des prompts de strategie. Les chemins sont relatifs a la racine du repo. Les cles subject_prompts/site_overrides/blog_to_subject_mapping ont ete retirees (2026-07-17) : elles pointaient sur _shared/prompts/sites/*.md, disparus au profit de tenants/{id}/prompts/site.md, et leur sortie n'etait consommee par personne (PromptComposer compose strategy + site.md).",
  "content_type_mapping": {
    "review_comparatif": {
      "base_prompt": "prompts/formats/comparatif_review.md",
      "required_sections": [
        "verdict",
        "tableau_comparatif",
        "pour_contre"
      ],
      "tone_override": "expert_analytique",
      "structure": {
        "must_have_rating": true,
        "rating_scale": 10,
        "comparison_table_required": true
      }
    },
    "guide_complet": {
      "base_prompt": "prompts/formats/guide_complete.md",
      "required_sections": [
        "introduction",
        "etapes",
        "faq"
      ],
      "tone_override": null,
      "structure": {
        "min_h2_sections": 4,
        "faq_required": true
      }
    },
    "listicle": {
      "base_prompt": "prompts/formats/listicle.md",
      "required_sections": [
        "introduction",
        "liste_numerotee",
        "conclusion"
      ],
      "tone_override": null,
      "structure": {
        "list_format": "numbered",
        "min_items": 5,
        "max_items": 15
      }
    },
    "tutoriel": {
      "base_prompt": "prompts/formats/tutoriel.md",
      "required_sections": [
        "prerequis",
        "etapes",
        "resultat"
      ],
      "tone_override": "pedagogique",
      "structure": {
        "step_by_step_required": true,
        "examples_required": true
      }
    },
    "blog_article": {
      "base_prompt": "prompts/formats/blog_article.md",
      "required_sections": [
        "introduction",
        "body",
        "conclusion"
      ],
      "tone_override": "natural_informal",
      "structure": {
        "paragraph_length": "3-5 sentences",
        "intro_max_paragraphs": 2
      }
    }
  },
  "strategy_prompts": {
    "title_optimization": {
      "file": "_shared/strategies/title_optimization.md",
      "trigger_conditions": [
        "ctr_low",
        "impressions_high"
      ],
      "scope": "title_meta_only",
      "estimated_tokens": 500
    },
    "semantic_reorientation": {
      "file": "_shared/strategies/semantic_reorientation.md",
      "trigger_conditions": [
        "keyword_decline",
        "variants_rising"
      ],
      "scope": "full_with_eeat",
      "estimated_tokens": 4000
    },
    "format_adaptation": {
      "file": "_shared/strategies/format_adaptation.md",
      "trigger_conditions": [
        "format_mismatch"
      ],
      "scope": "structure_change",
      "estimated_tokens": 3000
    },
    "partial_refresh": {
      "file": "_shared/strategies/full_refresh.md",
      "trigger_conditions": [
        "content_stale",
        "stats_outdated"
      ],
      "scope": "diff_based",
      "estimated_tokens": 1500
    }
  },
  "category_paths": {
    "education_reviews": "education/education_reviews.md",
    "education_general": "education/education_general.md"
  },
  "blog_to_category_mapping": {
    "enseigna": "education_reviews",
    "superprof-ressources": "education_general"
  },
  "eeat_levels": {
    "very_high": {
      "description": "YMYL content - maximum E-E-A-T requirements",
      "author_credentials_required": true,
      "sources_minimum": 2,
      "disclaimer_required": true,
      "expert_review_recommended": true
    },
    "high": {
      "description": "Educational content - strong E-E-A-T",
      "author_credentials_required": true,
      "sources_minimum": 1,
      "disclaimer_required": false,
      "expert_review_recommended": false
    },
    "medium_high": {
      "description": "Informational content - standard E-E-A-T",
      "author_credentials_required": true,
      "sources_minimum": 0,
      "disclaimer_required": false,
      "expert_review_recommended": false
    }
  }
}
