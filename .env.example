# Copy to `.env` and fill in. Git-ignored: never shared, never committed.
# Guide: onboarding/01-setup-machine.md (step 7). Values: maintainer's welcome kit.

# DataforSEO API Credentials (shared account — welcome kit)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Editorial Audit Configuration
EDITORIAL_AUDIT_ENABLED=false
EDITORIAL_AUDIT_BLOCK_THRESHOLD=4

# MCP Configuration
USE_PLAYWRIGHT_FALLBACK=true
CACHE_SCRAPED_HTML=true

# Credentials Paths (adapt to your machine — maintainer / non-Superprof sites only)
GOOGLE_SA_PATH=~/.credentials/google/google-service-account.json
DATAFORSEO_CREDENTIALS_PATH=~/.credentials/dataforseo/credentials.json

# Spreadsheet Configuration (only if you use /batch or /decide — name must
# match `spreadsheet_env` in your site.json)
SPREADSHEET_ID_SUPERPROF=
SPREADSHEET_ID_ENSEIGNA=

# YTG Configuration (shared key — welcome kit)
YTG_NEW_API_KEY=

# Notion (maintainer only — https://www.notion.so/my-integrations)
NOTION_TOKEN=

# --- SuperTeamSEO API ---
STSEO_EMAIL=
STSEO_PASSWORD=

# --- WordPress REST API ---
# Application Passwords: WP Admin → Users → Profile → Application Passwords
# Password format: "xxxx xxxx xxxx xxxx xxxx xxxx" (keep the spaces)
# Use the exact names you wrote in your site.json. Examples:

# Enseigna
WP_ENSEIGNA_URL=
WP_ENSEIGNA_USER=
WP_ENSEIGNA_APP_PASSWORD=

# Superprof Ressources FR
WP_SUPERPROF_RESSOURCES_URL=
WP_SUPERPROF_RESSOURCES_USER=
WP_SUPERPROF_RESSOURCES_APP_PASSWORD=
