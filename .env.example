# DataforSEO API Credentials
# Get your credentials at: https://dataforseo.com/
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

# Google Search Console (Optional)
# GSC_CLIENT_ID=your_gsc_client_id
# GSC_CLIENT_SECRET=your_gsc_client_secret

# WordPress REST API
# Requires Application Passwords enabled on the WP instance (Settings > Users > Application Passwords)
WP_SUPERPROF_US_URL=your_wp_blog_url_here
WP_SUPERPROF_US_USER=your_wp_username_here
WP_SUPERPROF_US_APP_PASSWORD=your_app_password_here

# Scraper Configuration
SCRAPER_TIMEOUT=30
SCRAPER_RATE_LIMIT_RPM=20

# Editorial Audit Configuration
EDITORIAL_AUDIT_ENABLED=true
EDITORIAL_AUDIT_BLOCK_THRESHOLD=4

# MCP Configuration
USE_PLAYWRIGHT_FALLBACK=true
CACHE_SCRAPED_HTML=true
